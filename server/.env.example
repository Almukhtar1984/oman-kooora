# ------------------ NODE ENV ---------------------- #
NODE_ENV="development"

# ------------------ Server PORT ---------------------- #
PORT=7000

# ------------------ API URL ---------------------- #
API_URL="http://localhost:7000"
REQUEST_BODY_LIMIT="1mb"
TRUST_PROXY="false"
GRAPHQL_MAX_DEPTH=8
GRAPHQL_MAX_COMPLEXITY=500

# ------------------ Dashboard URLs ---------------------- #
ADMIN_URL="http://localhost:3000"
EMPLOYEE_URL="http://localhost:3001"
SUPERVISOR_URL="http://localhost:3002"
CUSTOMER_URL="http://localhost:3003"

# ------------------ JWT ---------------------- #
SECRET_JWT="replace-me"
MAX_FAILED_LOGIN_ATTEMPTS=5
LOGIN_LOCK_MINUTES=15

# ------------------ Database ---------------------- #
DB_DEV_USERNAME="root"
DB_DEV_PASSWORD=""
DB_DEV_DATABASE="tomoh"
DB_SYNC_ALTER="false"

DB_PRO_USERNAME=""
DB_PRO_PASSWORD=""
DB_PRO_DATABASE=""

# ------------------ Mail / SMTP ---------------------- #
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="465"
SMTP_SECURE="true"
SMTP_USER=""
SMTP_PASS=""
ERROR_MAIL_TO=""
MAIL_FROM_NAME="Dorrah"
MAIL_FROM_EMAIL=""
MAIL_DEFAULT_TO_NAME="Recipient"
MAIL_DEFAULT_TO_EMAIL=""
